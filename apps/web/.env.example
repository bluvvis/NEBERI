# Скопируйте в .env.local и перезапустите vite (npm run dev).
# Должен совпадать с INGEST_API_KEY у API: apps/api/.env, docker-compose или переменная окружения.
VITE_INGEST_API_KEY=neberi-dev-docker-ingest

# Обычно не нужно: в vite.config.ts /v1 проксируется на http://127.0.0.1:8000
# VITE_API_BASE=http://127.0.0.1:8000
